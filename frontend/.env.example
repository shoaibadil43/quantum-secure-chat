# Frontend Environment Variables (.env.example)
# Copy this file to .env.local and fill in your actual values

# Backend API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/api/ws/chat

# On Production/Deployment:
# VITE_API_URL=https://quantum-secure-chat-backend-xxxx.onrender.com/api
# VITE_WS_URL=wss://quantum-secure-chat-backend-xxxx.onrender.com/api/ws/chat

# App Configuration
VITE_APP_NAME=Quantum Secure Chat
VITE_APP_VERSION=1.0.0
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ENCRYPTION=true
VITE_ENABLE_BB84=true
