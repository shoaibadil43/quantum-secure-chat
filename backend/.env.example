# Environment variables
DEBUG=False
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://quantum_user:quantum_pass@localhost:5432/quantum_chat
# Alternative for SQLite (development):
# DATABASE_URL=sqlite:///./quantum_chat.db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption Master Key (32 bytes base64 encoded)
MASTER_KEY=your-32-byte-master-key-for-encryption-base64-encoded

# BB84 Configuration
BB84_QUBIT_COUNT=4096
BB84_ERROR_THRESHOLD=0.11
BB84_SIFT_RATIO=0.5

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# Security Settings
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
